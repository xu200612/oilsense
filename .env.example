# OilSense API Key 配置模板
# 复制此文件为 .env 并填入对应 Key

# 必需（最简启动）
FRED_API_KEY=your_fred_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# 可选（新闻数据）
NEWS_API_KEY=your_newsapi_key_here

# 可选（航运数据）
AIS_API_KEY=your_aisstream_key_here
VESSELAPI_API_KEY=your_vesselapi_key_here
SHIPFINDER_API_KEY=your_shipfinder_key_here

# 可选（历史新闻）
MEDIACLOUD_API_KEY=your_mediacloud_key_here
MEDIACLOUD_COLLECTION_IDS=34412476,34412050,34412114

# 可选（备用行情）
ALPHA_VANTAGE_KEY=your_alphavantage_key_here
EIA_API_KEY=your_eia_key_here
